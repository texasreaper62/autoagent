#!/usr/bin/env bash
# Sync .agent/ core from the upstream template.
#
# Pulls template/core files (hooks, dream cycle, universal skills) from
# the canonical agentic-stack repo. Preserves repo-local customizations
# (memory/, repo-specific skills/, repo-specific protocols).
#
# Usage:
#   bin/agent-sync pull         # pull latest from upstream
#   bin/agent-sync status       # show version + drift vs upstream
set -euo pipefail

UPSTREAM="${AGENTIC_STACK_UPSTREAM:-https://github.com/texasreaper62/agentic-stack.git}"
PINNED_VERSION_FILE=".agent/.template-version"
SYNC_DIRS=(
  ".agent/harness/hooks"
  ".agent/memory/auto_dream.py"
  ".agent/memory/promote.py"
  ".agent/memory/decay.py"
  ".agent/memory/archive.py"
  ".agent/tools"
  ".agent/skills/skillforge"
  ".agent/skills/memory-manager"
  ".agent/skills/git-proxy"
  ".agent/skills/debug-investigator"
  ".agent/skills/deploy-checklist"
  ".agent/skills/context-compactor"
  ".agent/skills/rewind-handoff"
  ".agent/skills/session-boundaries"
)

usage() {
  sed -n '2,/^$/p' "$0" | sed 's/^# \?//'
  exit 1
}

action="${1:-}"
case "$action" in
  pull)
    tmpdir=$(mktemp -d)
    git clone --depth=1 "$UPSTREAM" "$tmpdir" >&2
    for path in "${SYNC_DIRS[@]}"; do
      if [[ -e "$tmpdir/$path" ]]; then
        mkdir -p "$(dirname "$path")"
        cp -r "$tmpdir/$path" "$(dirname "$path")/"
        echo "synced $path"
      fi
    done
    (cd "$tmpdir" && git rev-parse HEAD) > "$PINNED_VERSION_FILE"
    rm -rf "$tmpdir"
    echo "pinned version: $(cat "$PINNED_VERSION_FILE")"
    ;;
  status)
    if [[ -f "$PINNED_VERSION_FILE" ]]; then
      echo "pinned: $(cat "$PINNED_VERSION_FILE")"
    else
      echo "no pinned version; run: bin/agent-sync pull"
    fi
    ;;
  *)
    usage
    ;;
esac
